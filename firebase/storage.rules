rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null && request.auth.token.email is string;
    }
    function emailKey() {
      return request.auth.token.email.lower();
    }
    function ownerProfileExists() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }
    function ownerProfile() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }
    function isOwner() {
      return signedIn() && (
        emailKey() == 'a0965487920@gmail.com'
        || (ownerProfileExists()
          && ownerProfile().active != false
          && ownerProfile().companyId == 'danbridge'
          && ownerProfile().role == 'owner')
      );
    }
    function accessExists() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/companyAccess/$(emailKey()));
    }
    function access() {
      return firestore.get(/databases/(default)/documents/companyAccess/$(emailKey())).data;
    }
    function activeMember() {
      return accessExists()
        && access().active == true
        && access().companyId == 'danbridge';
    }
    function effectiveTeacherId() {
      return access().teacherId is string
        ? access().teacherId
        : (ownerProfileExists() && ownerProfile().teacherId is string
          ? ownerProfile().teacherId
          : '');
    }
    function effectiveBranchIds() {
      return access().branchIds is list
        ? access().branchIds
        : (ownerProfileExists() && ownerProfile().branchIds is list
          ? ownerProfile().branchIds
          : []);
    }
    function lessonMetaExists(lessonId) {
      return firestore.exists(/databases/(default)/documents/companies/danbridge/lessonMeta/$(lessonId));
    }
    function lessonMeta(lessonId) {
      return firestore.get(/databases/(default)/documents/companies/danbridge/lessonMeta/$(lessonId)).data;
    }
    function grantExists(lessonId) {
      return firestore.exists(/databases/(default)/documents/companies/danbridge/reportExtensionGrants/$(lessonId));
    }
    function grant(lessonId) {
      return firestore.get(/databases/(default)/documents/companies/danbridge/reportExtensionGrants/$(lessonId)).data;
    }
    function extensionOpen(lessonId) {
      return activeMember()
        && effectiveTeacherId() != ''
        && grantExists(lessonId)
        && lessonMetaExists(lessonId)
        && lessonMeta(lessonId).teacherIds is list
        && lessonMeta(lessonId).teacherIds.hasAny([effectiveTeacherId()])
        && grant(lessonId).lessonId == lessonId
        && grant(lessonId).extensionStatus == 'approved'
        && grant(lessonId).approvedForTeacherId == effectiveTeacherId()
        && grant(lessonId).approvedAt is timestamp
        && request.time <= grant(lessonId).approvedAt + duration.value(10, 'm');
    }
    function withinReportWindow(lessonId) {
      return lessonMetaExists(lessonId)
        && lessonMeta(lessonId).editableUntil is timestamp
        && (request.time <= lessonMeta(lessonId).editableUntil || extensionOpen(lessonId));
    }
    function teacherAssignedToLesson(lessonId) {
      return activeMember()
        && effectiveTeacherId() != ''
        && lessonMetaExists(lessonId)
        && lessonMeta(lessonId).active == true
        && lessonMeta(lessonId).teacherIds is list
        && lessonMeta(lessonId).teacherIds.hasAny([effectiveTeacherId()]);
    }
    function managerCanAccessBranch(lessonId) {
      return activeMember()
        && access().role == 'branch_manager'
        && effectiveBranchIds().hasAny([lessonMeta(lessonId).branchId]);
    }
    function canReadLesson(lessonId) {
      return teacherAssignedToLesson(lessonId)
        || (activeMember()
          && lessonMetaExists(lessonId)
          && lessonMeta(lessonId).active == true
          && managerCanAccessBranch(lessonId));
    }
    function canUploadOwnLesson(lessonId) {
      return teacherAssignedToLesson(lessonId)
        && (access().role == 'teacher'
          || access().role == 'branch_manager'
          || access().canSubmitOwnReports == true)
        && withinReportWindow(lessonId);
    }

    match /companies/danbridge/lessonReports/{lessonId}/{fileName} {
      allow read: if isOwner() || canReadLesson(lessonId);
      allow create, update: if (isOwner() || canUploadOwnLesson(lessonId))
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType is string
        && request.resource.contentType.matches('image/.*');
      allow delete: if isOwner();
    }
  }
}
