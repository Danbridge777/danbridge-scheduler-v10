rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null && request.auth.token.email is string; }
    function emailKey() { return request.auth.token.email.lower(); }
    function ownerProfileExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function ownerProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isOwner() {
      return signedIn() && (
        emailKey() == 'a0965487920@gmail.com'
        || (ownerProfileExists()
          && ownerProfile().active != false
          && ownerProfile().companyId == 'danbridge'
          && ownerProfile().role == 'owner')
      );
    }
    function accessExists() { return signedIn() && exists(/databases/$(database)/documents/companyAccess/$(emailKey())); }
    function access() { return get(/databases/$(database)/documents/companyAccess/$(emailKey())).data; }
    function activeMember(companyId) { return accessExists() && access().active == true && access().companyId == companyId; }
    function currentProfileExists() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function currentProfile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function effectiveTeacherId() {
      return access().teacherId is string
        ? access().teacherId
        : (currentProfileExists() && currentProfile().teacherId is string ? currentProfile().teacherId : '');
    }
    function effectiveBranchIds() {
      return access().branchIds is list
        ? access().branchIds
        : (currentProfileExists() && currentProfile().branchIds is list ? currentProfile().branchIds : []);
    }
    function isTeacher(companyId) { return activeMember(companyId) && access().role == 'teacher' && effectiveTeacherId() != ''; }
    function isManager(companyId) { return activeMember(companyId) && access().role == 'branch_manager' && effectiveTeacherId() != ''; }
    function ownTeacherId() { return effectiveTeacherId(); }
    function ownLessonReport(data) {
      return data.reportedForTeacherIds is list && data.reportedForTeacherIds.hasAny([ownTeacherId()]);
    }
    function managerBranch(data) {
      return data.branchId is string && effectiveBranchIds().hasAny([data.branchId]);
    }
    function metaPath(companyId, lessonId) {
      return /databases/$(database)/documents/companies/$(companyId)/lessonMeta/$(lessonId);
    }
    function extensionGrantPath(companyId, lessonId) {
      return /databases/$(database)/documents/companies/$(companyId)/reportExtensionGrants/$(lessonId);
    }
    function metaExists(companyId, lessonId) { return exists(metaPath(companyId, lessonId)); }
    function meta(companyId, lessonId) { return get(metaPath(companyId, lessonId)).data; }
    function extensionOpen(companyId, lessonId) {
      return exists(extensionGrantPath(companyId, lessonId))
        && metaExists(companyId, lessonId)
        && meta(companyId, lessonId).active == true
        && meta(companyId, lessonId).teacherIds is list
        && meta(companyId, lessonId).teacherIds.hasAny([ownTeacherId()])
        && get(extensionGrantPath(companyId, lessonId)).data.lessonId == lessonId
        && get(extensionGrantPath(companyId, lessonId)).data.extensionStatus == 'approved'
        && get(extensionGrantPath(companyId, lessonId)).data.approvedForTeacherId == ownTeacherId()
        && get(extensionGrantPath(companyId, lessonId)).data.approvedAt is timestamp
        && request.time <= get(extensionGrantPath(companyId, lessonId)).data.approvedAt + duration.value(10, 'm');
    }
    function withinReportWindow(companyId, lessonId) {
      return request.time <= meta(companyId, lessonId).editableUntil || extensionOpen(companyId, lessonId);
    }
    function matchesTrustedLesson(companyId, lessonId, data) {
      return metaExists(companyId, lessonId)
        && meta(companyId, lessonId).active == true
        && data.companyId == companyId
        && data.lessonId == lessonId
        && data.branchId == meta(companyId, lessonId).branchId
        && data.reportedForTeacherIds == meta(companyId, lessonId).teacherIds
        && data.editableUntil == meta(companyId, lessonId).editableUntil;
    }
    function trustedIdentityUpdate(companyId, lessonId) {
      return matchesTrustedLesson(companyId, lessonId, request.resource.data)
        && (!('companyId' in resource.data) || request.resource.data.companyId == resource.data.companyId)
        && (!('lessonId' in resource.data) || request.resource.data.lessonId == resource.data.lessonId)
        && (!('branchId' in resource.data) || request.resource.data.branchId == resource.data.branchId)
        && (!('reportedForTeacherIds' in resource.data) || request.resource.data.reportedForTeacherIds == resource.data.reportedForTeacherIds)
        && (!('editableUntil' in resource.data) || request.resource.data.editableUntil == resource.data.editableUntil);
    }
    function canSubmitOwnTeacherRequest(companyId, lessonId, data) {
      return activeMember(companyId)
        && (isTeacher(companyId) || isManager(companyId))
        && metaExists(companyId, lessonId)
        && meta(companyId, lessonId).active == true
        && meta(companyId, lessonId).teacherIds is list
        && meta(companyId, lessonId).teacherIds.hasAny([ownTeacherId()])
        && data.companyId == companyId
        && data.lessonId == lessonId
        && data.requesterUid == request.auth.uid
        && data.requesterEmail == emailKey()
        && data.requesterTeacherId == ownTeacherId()
        && data.lessonDate == meta(companyId, lessonId).lessonDate
        && data.lessonStart == meta(companyId, lessonId).lessonStart
        && data.lessonEnd == meta(companyId, lessonId).lessonEnd
        && data.studentId == meta(companyId, lessonId).studentId
        && data.teacherIds == meta(companyId, lessonId).teacherIds
        && data.extensionStatus == 'pending'
        && data.extensionMinutes == 10;
    }
    function extensionRequestFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'companyId','lessonId','branchId','reportedForTeacherIds','editableUntil',
        'extensionStatus','extensionMinutes','requesterTeacherId','requesterUid',
        'requesterEmail','requesterName','lessonDate','lessonStart','lessonEnd','studentId','teacherIds',
        'extensionRequestedAt','extensionRequestedAtClient','extensionUntil',
        'extensionUntilClient','approvedAt','approvedAtClient','approvedByUid','approvedByEmail'
      ]);
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isOwner());
      allow create: if signedIn() && request.auth.uid == uid
        && (isOwner() || (accessExists()
          && request.resource.data.email.lower() == emailKey()
          && request.resource.data.companyId == access().companyId
          && request.resource.data.role == access().role));
      allow update: if isOwner() || (
        signedIn() && request.auth.uid == uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.active == resource.data.active
        && request.resource.data.email == resource.data.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName','photoURL','lastLoginAt','updatedAt'
        ])
      ) || (
        signedIn() && request.auth.uid == uid
        && accessExists()
        && request.resource.data.email.lower() == emailKey()
        && request.resource.data.companyId == access().companyId
        && request.resource.data.role == access().role
        && request.resource.data.active == access().active
        && request.resource.data.teacherId == access().teacherId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName','photoURL','lastLoginAt','updatedAt','role','companyId','active',
          'teacherId','teacherName','managerName','branchIds','branchNames','readOnly','canSubmitOwnReports'
        ])
      );
      allow delete: if isOwner();
    }

    match /companyAccess/{email} {
      allow read: if isOwner() || (signedIn() && email == emailKey());
      allow write: if isOwner();
    }

    // Owner 對公司命名空間具有完整權限。Firestore 會將重疊 match 以 OR 判斷，
    // 因此 lessonMeta、lessonReports、teacherViews 等新增子集合不會因漏寫 match 而阻擋 Owner。
    match /companies/{companyId}/{document=**} {
      allow read, write: if isOwner();
    }

    match /companies/{companyId}/data/{documentId} {
      allow read, write: if isOwner();
    }

    match /companies/{companyId}/teacherViews/{email} {
      allow read: if isOwner() || (signedIn() && email == emailKey() && activeMember(companyId));
      allow write: if isOwner();
    }

    match /companies/{companyId}/branchViews/{email} {
      allow read: if isOwner() || (signedIn() && email == emailKey() && isManager(companyId));
      allow write: if isOwner();
    }

    match /companies/{companyId}/lessonMeta/{lessonId} {
      allow read: if isOwner() || activeMember(companyId);
      allow write: if isOwner();
    }

    match /companies/{companyId}/reportExtensionRequests/{lessonId} {
      allow read: if isOwner()
        || (activeMember(companyId) && resource.data.requesterUid == request.auth.uid);

      allow create: if request.resource.data.lessonId is string
        && lessonId == request.resource.data.lessonId
        && canSubmitOwnTeacherRequest(companyId, lessonId, request.resource.data)
        && request.resource.data.keys().hasOnly([
          'companyId','lessonId','requesterUid','requesterTeacherId','requesterEmail','requesterName',
          'lessonDate','lessonStart','lessonEnd','studentId','teacherIds','extensionStatus','extensionMinutes',
          'extensionRequestedAt','extensionRequestedAtClient','extensionUntil','extensionUntilClient',
          'approvedAt','approvedAtClient','approvedByUid','approvedByEmail'
        ]);

      allow update: if isOwner()
        || (
          activeMember(companyId)
          && resource.data.requesterUid == request.auth.uid
          && lessonId == request.resource.data.lessonId
          && canSubmitOwnTeacherRequest(companyId, lessonId, request.resource.data)
          && request.resource.data.keys().hasOnly([
            'companyId','lessonId','requesterUid','requesterTeacherId','requesterEmail','requesterName',
            'lessonDate','lessonStart','lessonEnd','studentId','teacherIds','extensionStatus','extensionMinutes',
            'extensionRequestedAt','extensionRequestedAtClient','extensionUntil','extensionUntilClient',
            'approvedAt','approvedAtClient','approvedByUid','approvedByEmail'
          ])
        );
      allow delete: if isOwner();
    }

    match /companies/{companyId}/reportExtensionGrants/{lessonId} {
      allow read: if isOwner() || activeMember(companyId);
      allow create, update: if isOwner()
        && request.resource.data.lessonId == lessonId
        && request.resource.data.lessonDate == meta(companyId, lessonId).lessonDate
        && request.resource.data.lessonStart == meta(companyId, lessonId).lessonStart
        && request.resource.data.lessonEnd == meta(companyId, lessonId).lessonEnd
        && request.resource.data.studentId == meta(companyId, lessonId).studentId
        && request.resource.data.teacherIds == meta(companyId, lessonId).teacherIds;
      allow delete: if isOwner();
    }

    match /companies/{companyId}/lessonReports/{lessonId} {
      allow read: if isOwner()
        || (
          (isTeacher(companyId) || isManager(companyId))
          && metaExists(companyId, lessonId)
          && meta(companyId, lessonId).teacherIds is list
          && meta(companyId, lessonId).teacherIds.hasAny([ownTeacherId()])
          && (isTeacher(companyId)
            || (meta(companyId, lessonId).branchId is string
              && effectiveBranchIds().hasAny([meta(companyId, lessonId).branchId])))
        );

      // The trusted lessonMeta document and the authenticated account determine permission.
      // Report payload display fields are not used as authorization inputs, preventing harmless
      // UID/teacher-array/legacy-field differences from causing a false permission-denied.
      allow create, update: if isOwner()
        || (
          (isTeacher(companyId) || isManager(companyId))
          && metaExists(companyId, lessonId)
          && meta(companyId, lessonId).active == true
          && meta(companyId, lessonId).teacherIds is list
          && meta(companyId, lessonId).teacherIds.hasAny([ownTeacherId()])
          && request.resource.data.companyId == companyId
          && request.resource.data.lessonId == lessonId
          && (isTeacher(companyId)
            || (meta(companyId, lessonId).branchId is string
              && effectiveBranchIds().hasAny([meta(companyId, lessonId).branchId])))
          && withinReportWindow(companyId, lessonId)
        );

      allow delete: if isOwner();
    }
  }
}
